# create_svc_model.py
import torch
import torch.nn as nn

class SVCModel(nn.Module):
    def __init__(self):
        super().__init__()
        # Encoder-decoder with skip connections
        self.encoder = nn.Sequential(
            nn.Conv1d(80, 256, 5, padding=2),
            nn.BatchNorm1d(256),
            nn.ReLU(),
            nn.Conv1d(256, 512, 5, padding=2),
            nn.BatchNorm1d(512),
            nn.ReLU(),
        )
        self.decoder = nn.Sequential(
            nn.ConvTranspose1d(512, 256, 5, padding=2),
            nn.BatchNorm1d(256),
            nn.ReLU(),
            nn.ConvTranspose1d(256, 80, 5, padding=2),
            nn.Tanh()
        )

    def forward(self, x):
        x = self.encoder(x)
        return self.decoder(x)

model = SVCModel()
torch.save(model.state_dict(), 'models/voice_cloning/svc_model.pth')
