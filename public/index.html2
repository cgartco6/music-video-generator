<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Music Video Studio</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white">
  <div class="max-w-4xl mx-auto p-6">
    <h1 class="text-4xl font-bold mb-8">AI Music Video Generator</h1>
    <input type="file" id="song" accept="audio/*">
    <button onclick="generate()" class="bg-blue-600 px-6 py-3 mt-4">Generate Video with Custom Singers</button>
    <div id="status"></div>
  </div>
  <script>
    function generate() {
      document.getElementById('status').innerHTML = 'Generating realistic video with male/female singers... (demo)';
    }
  </script>
</body>
</html>
