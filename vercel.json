{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python",
      "config": {
        "pythonVersion": "3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app/main.py"
    }
  ],
  "env": {
    "DEBUG": "False",
    "USE_GPU": "False",
    "MAX_FILE_SIZE": "52428800",
    "LIBROSA_BACKEND": "soundfile"
  },
  "buildCommand": "bash build.sh"
}
